# secrets — NEVER commit (Azure keys live here)
.env
.env.local
.env.*.local

# dependencies
node_modules/

# generated / regenerable / heavy
designs/*/comparison.html
designs/*/.comparison-work/
output/.verify/
replicas/.slot-images/
replicas/*.best.html

# logs & temp
*.log
*.tmp
.tmp/

# tooling state
.omc/
.progress/
runs/

# raw Canva capture artifacts (large; may embed session tokens) — never commit
designs/*/capture/
# intermediate authoring scratch (output/ holds the final templates)
replicas/
# capture URL manifests contain Canva presigned S3 URLs (X-Amz-Credential) — never commit
designs/*/extract/document-image-urls.json
designs/*/extract/assets/download-manifest.json

# generated slot photos (large, regenerable)
output/.slot-images/
*.imagelock

# seed-ready copies emitted by publish-images.mjs — same HTML as output/*.html but with
# photo srcs rewritten to the hosted blob URLs. Environment-specific (they bake in one
# account's public base URL) and fully regenerable, so they are a build artefact, not a
# deliverable. output/*.html stays the source of truth.
output/.seed/

# session render artifacts + comparison boards (temp)
output/.agent/
output/.hand/
output/.worker/
output/_compare*.html
output/_recolor*
output/_slide-*
output/hand-*.html

# build artefacts — never deliverables; output/ holds ONLY final template HTML
.renders/
.slot-images/
.dashboard.lock
.locks/
