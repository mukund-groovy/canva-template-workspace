# Azure OpenAI — image generation for carousel archetype photo slots.
# Copy to `.env` (gitignored) and fill in. Never commit real values.

# Resource endpoint, no trailing slash.
#   e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=

# API key from the Azure portal → your resource → Keys and Endpoint.
AZURE_OPENAI_API_KEY=

# The DEPLOYMENT name you created for the image model (not the model name).
#   e.g. gpt-image-1  /  dall-e-3
AZURE_OPENAI_IMAGE_DEPLOYMENT=

# API version for the images endpoint.
AZURE_OPENAI_API_VERSION=2024-10-21

# Optional defaults for generated slot images.
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=high

# generation provider: codex (Azure OpenAI Responses) | claude (Azure AI Foundry Anthropic)
GEN_PROVIDER=codex
AZURE_ANTHROPIC_ENDPOINT=https://<resource>.services.ai.azure.com/anthropic
AZURE_ANTHROPIC_MODEL=claude-opus-4-8
AZURE_ANTHROPIC_API_KEY=your-anthropic-foundry-key
