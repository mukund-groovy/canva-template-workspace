# Copy to `.env` (gitignored) and fill in. Never commit real values.
#
# Three groups: TEXT generation (authors the template HTML), IMAGE generation (fills photo
# slots), and BLOB STORAGE (hosts those photos at seed time).

# ─────────────────────────────────────────────────────────────────────────────
# TEXT generation — which provider authors the template HTML
# ─────────────────────────────────────────────────────────────────────────────

# codex (Azure OpenAI Responses API) | claude (Azure AI Foundry Anthropic)
GEN_PROVIDER=claude

# --- codex path (GEN_PROVIDER=codex) ---
# Resource endpoint, no trailing slash. e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=
# API key: Azure portal → your resource → Keys and Endpoint.
AZURE_OPENAI_API_KEY=
# The text model/deployment name used for authoring + planning. e.g. gpt-5.3-codex
AZURE_TEXT_MODEL=

# --- claude path (GEN_PROVIDER=claude) ---
AZURE_ANTHROPIC_ENDPOINT=https://<resource>.services.ai.azure.com/anthropic
AZURE_ANTHROPIC_MODEL=claude-opus-4-8
AZURE_ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# IMAGE generation — fills <img data-image="true"> photo slots
# ─────────────────────────────────────────────────────────────────────────────
# Provider resolution (first COMPLETE set wins): AZURE_IMAGE_* is preferred over
# AZURE_OPENAI_IMAGE_DEPLOYMENT. See scripts/fill-image-slots.mjs.

# Preferred: a dedicated image endpoint/key/model.
AZURE_IMAGE_ENDPOINT=
AZURE_IMAGE_API_KEY=
AZURE_IMAGE_MODEL=

# Fallback: an image DEPLOYMENT name on the AZURE_OPENAI_* resource above
# (the deployment name, not the model name). e.g. gpt-image-1 / dall-e-3
AZURE_OPENAI_IMAGE_DEPLOYMENT=
# API version for the images endpoint.
AZURE_OPENAI_API_VERSION=2024-10-21

# Defaults for generated slot images. IMPORTANT: these are the image API's OWN valid
# sizes (1024x1024 or 1024x1536) — never the design canvas size (1080x1350 etc). CSS
# object-fit scales the result to whatever box it lands in; passing a canvas size fails
# with a confusing "divisible by 1" 400.
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=high

# ─────────────────────────────────────────────────────────────────────────────
# BLOB STORAGE — hosts template photos at seed time
# ─────────────────────────────────────────────────────────────────────────────
# Photos ship as FILES beside the template (output/assets/images/<slug>/slide-03.png),
# referenced by a relative path — never inlined as base64 (see CLAUDE.md "Photos are
# files, not base64"). At seed time they are uploaded here and the relative prefix is
# swapped for the public URL.
#
# NOTE: the container is typically SHARED with other services, so uploads go under the
# UPLOAD_DIR prefix rather than the container root.

# Storage account name (not the full URL). e.g. mystorageaccount
AZURE_STORAGE_ACCOUNT_NAME=
# Account access key: Azure portal → storage account → Access keys. 88-char base64.
AZURE_STORAGE_ACCESS_KEY=
# Container name. Must allow public blob read for the hosted URLs to resolve.
AZURE_STORAGE_CONTAINER=
# Public base URL for that container, no trailing slash.
#   https://<account>.blob.core.windows.net/<container>
AZURE_STORAGE_PUBLIC_BASE_URL=
# Prefix (virtual folder) inside the container for THIS project's uploads, so template
# images never collide with whatever else shares the container.
UPLOAD_DIR=./social-templates
